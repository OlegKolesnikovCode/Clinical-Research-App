# PostgreSQL connection string used by Prisma

# Local development example:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/clinical_research_app"

# Cloud (e.g., Neon) example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/clinical_research_app?sslmode=require"

# Required environment variable
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?sslmode=require"